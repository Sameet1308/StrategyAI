# =============================================================
# Strategy (MicroStrategy) Dual-Server Configuration
# =============================================================

# PROD server (source — extract lineage data)
MSTR_PROD_BASE_URL=https://prod-server/MicroStrategyLibrary/api

# DEV server (target — publish lineage cubes)
MSTR_DEV_BASE_URL=https://dev-server/MicroStrategyLibrary/api

# Credentials (same user has access to both servers)
MSTR_USERNAME=your_username
MSTR_PASSWORD=your_password

# DEV target: project and folder where lineage cubes will be published
MSTR_DEV_PROJECT_ID=your_dev_project_id
MSTR_DEV_FOLDER_ID=your_dev_folder_id

# PROD source: comma-separated project IDs to extract lineage from
MSTR_PROD_PROJECT_IDS=project_id_1,project_id_2,project_id_3

# =============================================================
# Legacy single-server config (for simple admin scripts)
# =============================================================
# MSTR_BASE_URL=https://your-server/MicroStrategyLibrary/api
# MSTR_PROJECT_ID=
# MSTR_VERIFY_SSL=true
