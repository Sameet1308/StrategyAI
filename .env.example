# Strategy (MicroStrategy) Server Configuration
MSTR_BASE_URL=https://your-server/MicroStrategyLibrary/api
MSTR_USERNAME=your_username
MSTR_PASSWORD=your_password

# Optional: Project ID (if scripts target a specific project)
MSTR_PROJECT_ID=

# Optional: SSL verification (set to false for self-signed certs)
MSTR_VERIFY_SSL=true
